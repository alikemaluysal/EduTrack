<!DOCTYPE html>
<html lang="en">
<head>
    <partial name="Partials/Layout/_Head" />
    <title>@ViewData["Title"] - EduTrack</title>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    
    <partial name="Partials/Layout/_Navbar" />



    <div class="container-fluid app-shell">
        <div class="row">
            <partial name="Partials/Layout/_Sidebar" />

            <main class="col-lg-10 p-4">
                @RenderBody()
            </main>
        </div>
    </div>


    <div class="modal fade" id="createCourse" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h2 class="modal-title h5">Create course</h2><button class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input class="form-control mb-3" placeholder="Course name"><input class="form-control mb-3" placeholder="Section"><textarea class="form-control" rows="3"
                                                                                                                                                placeholder="Description"></textarea>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-outline-secondary"
                            data-bs-dismiss="modal">
                        Cancel
                    </button><button class="btn btn-success">Save course</button>
                </div>
            </div>
        </div>
    </div>

    <partial name="Partials/Layout/_Scripts" />
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
