@using EduTrack.Web.Models.Users
@model EditUserViewModel

@{
    ViewData["Title"] = "Edit user";
}

<div class="container py-4">
    <div class="d-flex flex-wrap align-items-center justify-content-between gap-3 mb-4">
        <div>
            <h1 class="page-title h2 mb-1">Edit user</h1>
            <p class="text-muted mb-0">@Model.Email</p>
        </div>
        <a class="btn btn-outline-secondary" asp-action="Index">Back to users</a>
    </div>

    <partial name="Partials/_ErrorMessageAlert" />

    <form method="post" class="row g-4">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />

        <div class="col-lg-8">
            <div class="card">
                <div class="card-body p-4">
                    <h2 class="h5 page-title mb-4">Profile details</h2>

                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label" asp-for="FirstName"></label>
                            <input class="form-control" asp-for="FirstName" />
                            <span class="text-danger small" asp-validation-for="FirstName"></span>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label" asp-for="LastName"></label>
                            <input class="form-control" asp-for="LastName" />
                            <span class="text-danger small" asp-validation-for="LastName"></span>
                        </div>
                        <div class="col-12">
                            <label class="form-label" asp-for="Email"></label>
                            <input class="form-control" asp-for="Email" />
                            <span class="text-danger small" asp-validation-for="Email"></span>
                        </div>
                        <div class="col-12">
                            <div class="form-check form-switch">
                                <input class="form-check-input" asp-for="IsActive" />
                                <label class="form-check-label" asp-for="IsActive">Active account</label>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card">
                <div class="card-body p-4">
                    <h2 class="h5 page-title mb-3">Roles</h2>

                    <div class="d-grid gap-2">
                        @foreach (var role in Model.Roles)
                        {
                            <label class="form-check border rounded-2 p-3 ps-5 bg-white">
                                <input class="form-check-input" type="checkbox" name="SelectedRoleIds" value="@role.Id" checked="@Model.SelectedRoleIds.Contains(role.Id)" />
                                <span class="form-check-label">@role.Name</span>
                            </label>
                        }
                    </div>
                </div>
            </div>

            <div class="d-grid gap-2 mt-3">
                <button type="submit" class="btn btn-success">Save changes</button>
                <a class="btn btn-outline-secondary" asp-action="Index">Cancel</a>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
