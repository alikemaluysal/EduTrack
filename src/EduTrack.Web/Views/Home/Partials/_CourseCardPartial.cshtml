@using EduTrack.Application.DTOs.Course
@model CourseListDto

<div class="card h-100">
    <div class="course-banner p-4 rounded-top">
        <h2 class="h4 mb-1">@Model.Title</h2>
        <p class="mb-0">@Model.InstructorFullName</p>
    </div>

    <div class="card-body">
        <p class="text-secondary">@Model.Description</p>

        <div class="d-flex align-items-center gap-3">
            <span class="badge text-bg-success p-2">@Model.StudentCount students</span>


            @if (!string.IsNullOrEmpty(Model.Code))
            {
                <div class="course-code-box">
                    <span class="course-code-label">Code</span>

             
                    <span class="course-code-value">@Model.Code</span>

                    <button type="button"
                            class="course-code-copy-btn"
                            data-copy-code="@Model.Code"
                            title="Copy code">
                        <i class="bi bi-copy"></i>
                    </button>
                </div>
            }


            <a href="course-detail.html" class="btn btn-outline-success btn-sm">Open</a>
        </div>
    </div>
</div>

<script>
    document.addEventListener("click", async function (e) {
        const button = e.target.closest("[data-copy-code]");
        if (!button) return;

        const code = button.dataset.copyCode;

        await navigator.clipboard.writeText(code);

        const icon = button.querySelector("i");
        icon.className = "bi bi-check2";

        setTimeout(() => {
            icon.className = "bi bi-copy";
        }, 1200);
    });
</script>


